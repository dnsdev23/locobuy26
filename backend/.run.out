query: TRUNCATE TABLE blog_posts, group_buys, products, pickup_locations, users RESTART IDENTITY CASCADE
query: SELECT COUNT(DISTINCT("product"."id")) AS "cnt" FROM "products" "product" LEFT JOIN "pickup_locations" "location" ON "location"."id"="product"."pickup_location_id"  LEFT JOIN "users" "seller" ON "seller"."id"="product"."seller_id" WHERE "product"."is_available" = $1 AND ST_DWithin(
          location.location::geography,
          ST_GeomFromText($2, 4326)::geography,
          $3
        ) -- PARAMETERS: [true,"POINT(120.6836 24.1637)",10000]
query: SELECT "BlogPost"."id" AS "BlogPost_id", "BlogPost"."title" AS "BlogPost_title", "BlogPost"."excerpt" AS "BlogPost_excerpt", "BlogPost"."content" AS "BlogPost_content", "BlogPost"."cover_image_url" AS "BlogPost_cover_image_url", "BlogPost"."type" AS "BlogPost_type", "BlogPost"."tags" AS "BlogPost_tags", "BlogPost"."is_published" AS "BlogPost_is_published", "BlogPost"."author_id" AS "BlogPost_author_id", "BlogPost"."created_at" AS "BlogPost_created_at", "BlogPost"."updated_at" AS "BlogPost_updated_at", "BlogPost__BlogPost_author"."id" AS "BlogPost__BlogPost_author_id", "BlogPost__BlogPost_author"."email" AS "BlogPost__BlogPost_author_email", "BlogPost__BlogPost_author"."password" AS "BlogPost__BlogPost_author_password", "BlogPost__BlogPost_author"."name" AS "BlogPost__BlogPost_author_name", "BlogPost__BlogPost_author"."phone" AS "BlogPost__BlogPost_author_phone", "BlogPost__BlogPost_author"."role" AS "BlogPost__BlogPost_author_role", "BlogPost__BlogPost_author"."avatar_url" AS "BlogPost__BlogPost_author_avatar_url", "BlogPost__BlogPost_author"."bio" AS "BlogPost__BlogPost_author_bio", "BlogPost__BlogPost_author"."is_active" AS "BlogPost__BlogPost_author_is_active", "BlogPost__BlogPost_author"."created_at" AS "BlogPost__BlogPost_author_created_at", "BlogPost__BlogPost_author"."updated_at" AS "BlogPost__BlogPost_author_updated_at" FROM "blog_posts" "BlogPost" LEFT JOIN "users" "BlogPost__BlogPost_author" ON "BlogPost__BlogPost_author"."id"="BlogPost"."author_id" WHERE (("BlogPost"."is_published" = $1)) ORDER BY "BlogPost"."created_at" DESC -- PARAMETERS: [true]
query: SELECT DISTINCT "distinctAlias"."product_id" AS "ids_product_id", "distinctAlias"."distance" FROM (SELECT "product"."id" AS "product_id", "product"."name" AS "product_name", "product"."description" AS "product_description", "product"."price" AS "product_price", "product"."stock" AS "product_stock", "product"."category" AS "product_category", "product"."external_link" AS "product_external_link", "product"."image_urls" AS "product_image_urls", "product"."is_available" AS "product_is_available", "product"."seller_id" AS "product_seller_id", "product"."pickup_location_id" AS "product_pickup_location_id", "product"."created_at" AS "product_created_at", "product"."updated_at" AS "product_updated_at", "location"."id" AS "location_id", "location"."name" AS "location_name", "location"."address" AS "location_address", "location"."city" AS "location_city", "location"."postal_code" AS "location_postal_code", "location"."country" AS "location_country", ST_AsGeoJSON("location"."location")::json AS "location_location", "location"."latitude" AS "location_latitude", "location"."longitude" AS "location_longitude", "location"."operating_hours" AS "location_operating_hours", "location"."phone" AS "location_phone", "location"."email" AS "location_email", "location"."description" AS "location_description", "location"."image_url" AS "location_image_url", "location"."is_active" AS "location_is_active", "location"."created_at" AS "location_created_at", "location"."updated_at" AS "location_updated_at", "seller"."id" AS "seller_id", "seller"."email" AS "seller_email", "seller"."password" AS "seller_password", "seller"."name" AS "seller_name", "seller"."phone" AS "seller_phone", "seller"."role" AS "seller_role", "seller"."avatar_url" AS "seller_avatar_url", "seller"."bio" AS "seller_bio", "seller"."is_active" AS "seller_is_active", "seller"."created_at" AS "seller_created_at", "seller"."updated_at" AS "seller_updated_at", ST_Distance(
          location.location::geography,
          ST_GeomFromText($1, 4326)::geography
        ) / 1000 AS "distance" FROM "products" "product" LEFT JOIN "pickup_locations" "location" ON "location"."id"="product"."pickup_location_id"  LEFT JOIN "users" "seller" ON "seller"."id"="product"."seller_id" WHERE "product"."is_available" = $2 AND ST_DWithin(
          location.location::geography,
          ST_GeomFromText($1, 4326)::geography,
          $3
        )) "distinctAlias" ORDER BY "distinctAlias"."distance" ASC, "product_id" ASC LIMIT 60 OFFSET 0 -- PARAMETERS: ["POINT(120.6836 24.1637)",true,10000]
