query: CREATE TABLE "blog_posts" ("id" uuid NOT NULL DEFAULT uuid_generate_v4(), "title" character varying NOT NULL, "excerpt" text NOT NULL, "content" text NOT NULL, "cover_image_url" character varying, "type" "public"."blog_posts_type_enum" NOT NULL DEFAULT 'buyer_experience', "tags" text, "is_published" boolean NOT NULL DEFAULT true, "author_id" uuid NOT NULL, "created_at" TIMESTAMP NOT NULL DEFAULT now(), "updated_at" TIMESTAMP NOT NULL DEFAULT now(), CONSTRAINT "PK_dd2add25eac93daefc93da9d387" PRIMARY KEY ("id"))
