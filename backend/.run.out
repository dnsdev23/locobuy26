query: SELECT "Product"."id" AS "Product_id", "Product"."name" AS "Product_name", "Product"."description" AS "Product_description", "Product"."price" AS "Product_price", "Product"."stock" AS "Product_stock", "Product"."category" AS "Product_category", "Product"."external_link" AS "Product_external_link", "Product"."image_urls" AS "Product_image_urls", "Product"."is_available" AS "Product_is_available", "Product"."seller_id" AS "Product_seller_id", "Product"."pickup_location_id" AS "Product_pickup_location_id", "Product"."created_at" AS "Product_created_at", "Product"."updated_at" AS "Product_updated_at", "Product__Product_seller"."id" AS "Product__Product_seller_id", "Product__Product_seller"."email" AS "Product__Product_seller_email", "Product__Product_seller"."password" AS "Product__Product_seller_password", "Product__Product_seller"."name" AS "Product__Product_seller_name", "Product__Product_seller"."phone" AS "Product__Product_seller_phone", "Product__Product_seller"."role" AS "Product__Product_seller_role", "Product__Product_seller"."avatar_url" AS "Product__Product_seller_avatar_url", "Product__Product_seller"."bio" AS "Product__Product_seller_bio", "Product__Product_seller"."is_active" AS "Product__Product_seller_is_active", "Product__Product_seller"."created_at" AS "Product__Product_seller_created_at", "Product__Product_seller"."updated_at" AS "Product__Product_seller_updated_at" FROM "products" "Product" LEFT JOIN "users" "Product__Product_seller" ON "Product__Product_seller"."id"="Product"."seller_id"
query: START TRANSACTION
