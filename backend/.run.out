query: INSERT INTO "blog_posts"("id", "title", "excerpt", "content", "cover_image_url", "type", "tags", "is_published", "author_id", "created_at", "updated_at") VALUES (DEFAULT, $1, $2, $3, $4, $5, $6, DEFAULT, $7, DEFAULT, DEFAULT) RETURNING "id", "type", "is_published", "created_at", "updated_at" -- PARAMETERS: ["North Tech Repair launches 24-hour iPhone battery service","A seller opening post explaining the convenience-store drop-off flow and turnaround time.","North Tech Repair is opening a faster 24-hour battery replacement lane for commuters in North District. Customers can place the service order in Locobuy, drop the phone at a nearby convenience store, and pick it up the next day from the same point. This opening campaign is designed for office workers and students who do not want to wait inside a repair shop.","https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=800","seller_promo","opening,3c repair,iphone","2e308f80-14a1-409d-acfa-32dc8cd19c12"]
query: COMMIT
query: START TRANSACTION
query: INSERT INTO "blog_posts"("id", "title", "excerpt", "content", "cover_image_url", "type", "tags", "is_published", "author_id", "created_at", "updated_at") VALUES (DEFAULT, $1, $2, $3, $4, $5, $6, DEFAULT, $7, DEFAULT, DEFAULT) RETURNING "id", "type", "is_published", "created_at", "updated_at" -- PARAMETERS: ["Glow Beauty Studio opening week promotion","A seller post introducing facial, lash, and nail service vouchers for North District buyers.","Glow Beauty Studio is using Locobuy to launch opening-week beauty vouchers that can be purchased online and redeemed later. Buyers can pay through the marketplace, collect a confirmation through a nearby convenience store pickup point, and schedule their service without repeated messaging. The goal is to make first-time discovery easier and lower the friction of trying a new studio.","https://images.unsplash.com/photo-1515377905703-c4788e51af15?w=800","seller_promo","opening,beauty,promotion","246159dd-9840-4970-bc55-001625175b73"]
query: COMMIT
query: START TRANSACTION
query: INSERT INTO "blog_posts"("id", "title", "excerpt", "content", "cover_image_url", "type", "tags", "is_published", "author_id", "created_at", "updated_at") VALUES (DEFAULT, $1, $2, $3, $4, $5, $6, DEFAULT, $7, DEFAULT, DEFAULT) RETURNING "id", "type", "is_published", "created_at", "updated_at" -- PARAMETERS: ["My first Locobuy repair drop-off was smoother than expected","A buyer shares how the convenience-store flow worked for a phone battery replacement.","I booked an iPhone battery replacement through Locobuy and used the 7-ELEVEN Zhongqing Store drop-off point. The process felt closer to parcel pickup than a traditional repair workflow. I received clear status updates, the device came back the next day, and I did not need to carve out time to sit in a repair shop. For repeat repairs, this is the model I would choose again.","https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=800","buyer_experience","buyer story,3c repair,pickup","2a2bcd6b-6502-472a-9d1c-34afbb58a261"]
query: COMMIT
query: START TRANSACTION
query: INSERT INTO "blog_posts"("id", "title", "excerpt", "content", "cover_image_url", "type", "tags", "is_published", "author_id", "created_at", "updated_at") VALUES (DEFAULT, $1, $2, $3, $4, $5, $6, DEFAULT, $7, DEFAULT, DEFAULT) RETURNING "id", "type", "is_published", "created_at", "updated_at" -- PARAMETERS: ["Two lunches, one pickup stop: trying restaurant preorders in North District","A buyer review covering bento and late-night snack pickups from convenience-store points.","I tested both the Braised Pork Rice Bento and the Frozen Salt Crispy Chicken Pack using FamilyMart Yizhong Store as the pickup point. The lunch preorder was useful during a busy workday, and the frozen snack pack was practical to pick up after work without coordinating directly with the restaurant. The service works best when you want local food but do not want delivery timing pressure.","https://images.unsplash.com/photo-1547592180-85f173990554?w=800","buyer_experience","restaurant,buyer story,north district","744a21a5-fd61-4357-9434-f1b3eafba4c6"]
query: COMMIT
query: START TRANSACTION
query: INSERT INTO "blog_posts"("id", "title", "excerpt", "content", "cover_image_url", "type", "tags", "is_published", "author_id", "created_at", "updated_at") VALUES (DEFAULT, $1, $2, $3, $4, $5, $6, DEFAULT, $7, DEFAULT, DEFAULT) RETURNING "id", "type", "is_published", "created_at", "updated_at" -- PARAMETERS: ["Why we moved our cafe subscription promo onto Locobuy","A seller explains how blog content and pickup points help convert local discovery into orders.","Yizhong Bento Kitchen started offering bottled cold brew through Locobuy because convenience-store pickup removes the need for strict handoff timing. Posting updates in the blog lets us explain new menu drops, pickup rules, and preorder windows in one place. It works as a small promotional channel without having to build a separate content site.","https://images.unsplash.com/photo-1461023058943-07fcbe16d735?w=800","seller_promo","cafe,seller story,promotion","aaa5d5b2-400a-47a3-a033-c4fc14e25a16"]
query: COMMIT
query: START TRANSACTION
query: INSERT INTO "blog_posts"("id", "title", "excerpt", "content", "cover_image_url", "type", "tags", "is_published", "author_id", "created_at", "updated_at") VALUES (DEFAULT, $1, $2, $3, $4, $5, $6, DEFAULT, $7, DEFAULT, DEFAULT) RETURNING "id", "type", "is_published", "created_at", "updated_at" -- PARAMETERS: ["Beauty voucher purchase experience after work","A buyer writes about booking a facial voucher and redeeming it later.","I bought the Hydrating Facial Voucher through Locobuy because I did not want to coordinate timing while still deciding on a date. The purchase flow felt like buying a normal item, and the seller later confirmed redemption times. This is a useful model for beauty services that are normally hard to compare when you are browsing late at night.","https://images.unsplash.com/photo-1571781926291-c477ebfd024b?w=800","buyer_experience","beauty,buyer story,voucher","39459fd4-6ff9-4f81-a8ee-c5443ce7102f"]
